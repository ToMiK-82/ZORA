# Конфигурация ZORA
# Скопируйте этот файл в .env и заполните значения

# === LLM провайдеры ===

# DeepSeek API (облачный вариант)
# Получите API ключ на https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-82788378fe7c4d1cbe4504c79d57ce46

# DeepSeek V4 модели (основной режим с 2026-07-24)
# V4 Flash — быстрая, дёшевая, поддерживает thinking и Function Calling
# V4 Pro — максимальная производительность, reasoning_effort
DEEPSEEK_MODEL_FLASH=deepseek-v4-flash
DEEPSEEK_MODEL_PRO=deepseek-v4-pro

# DeepSeek Legacy модели (для обратной совместимости, до 2026-07-24)
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# Режим обратной совместимости: false = V4, true = Legacy
DEEPSEEK_LEGACY_MODE=false

# Режим мышления по умолчанию: "none", "flash", "pro"
# none — без мышления (только обычный ответ)
# flash — V4 Flash с thinking (рекомендуется)
# pro — V4 Pro с reasoning_effort=high
DEEPSEEK_DEFAULT_REASONING=flash

# Ollama (локальный вариант)
# Установите Ollama: https://ollama.com/
# Запустите: ollama serve
# Скачайте модели: ollama pull deepseek-r1:32b:q5_K_M

# === Модели Ollama ===
# Модель для исполнителя действий (developer_assistant)
OLLAMA_EXECUTOR_MODEL=llama3.2:latest
# Модель для визуального контроля (скриншоты)
OLLAMA_VISION_MODEL=llama3.2:latest
# Модель для эмбеддингов (векторное представление текста)
EMBED_MODEL=nomic-embed-text

# === Базы данных ===

# PostgreSQL (основная БД)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=zora
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# Qdrant (векторная БД)
QDRANT_HOST=10.160.68.222   # IP-адрес сервера с Qdrant
QDRANT_PORT=6333
QDRANT_CONTAINER=zora_qdrant   # имя Docker-контейнера (только для локального управления)
QDRANT_VOLUME=E:/qdrant_data   # путь к данным на сервере (для docker run)

# Redis (кэширование)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# === API ключи для интеграций ===

# Wildberries API
WB_API_KEY=your_wb_api_key_here
WB_STAT_API_KEY=your_wb_stat_api_key_here

# Ozon API
OZON_CLIENT_ID=your_ozon_client_id_here
OZON_API_KEY=your_ozon_api_key_here

# 1C API
# URL REST сервиса 1С (OData). Пример: http://server:port/1c/ws/odata/standard.odata/
ONEC_API_URL=http://localhost:8080/1c/ws/odata/standard.odata/
# Имя пользователя для доступа к 1С
ONEC_API_USER=ZORA
# Пароль для доступа к 1С
ONEC_API_PASSWORD=Globus

# === Telegram бот ===
TELEGRAM_BOT_TOKEN=8726669674:AAGJOD4K4PeTHDpRH1Oqf1XDQEYgSrYFjSI
# === Настройки логирования ===
LOG_LEVEL=INFO
LOG_FILE=logs/zora.log

# === Настройки системы ===
# Приоритет провайдера LLM: ollama, deepseek, auto
LLM_PREFERRED_PROVIDER=auto

# Таймауты (в секундах)
API_TIMEOUT=30
OLLAMA_TIMEOUT=60
DEEPSEEK_TIMEOUT=30

# === Дополнительные настройки ===
# Режим отладки
DEBUG=false

# Автоматическое обновление цен
AUTO_REPRICING=false

# Интервал проверки остатков (в минутах)
INVENTORY_CHECK_INTERVAL=60

# Интервал отправки отчетов (в часах)
REPORT_INTERVAL=24